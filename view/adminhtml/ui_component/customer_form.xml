<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="groomershop_status" sortOrder="21">
        <settings>
            <label translate="true">GroomerShop</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>

        <field name="breeder_status" formElement="select" sortOrder="90">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">customer</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Status hodowcy</label>
                <dataScope>breeder_status</dataScope>
                <visible>true</visible>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="wholesaler_status" formElement="select" sortOrder="110">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">customer</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Status hurtownika</label>
                <dataScope>wholesaler_status</dataScope>
                <visible>true</visible>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>

        <field name="admin_comments" formElement="textarea" sortOrder="160">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">customer</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Uwagi (dla administratora)</label>
                <dataScope>admin_comments</dataScope>
                <visible>true</visible>
            </settings>
        </field>
    </fieldset>
</form>
